<div class="w-full max-w-3xl">
  <div class="flex justify-between items-center mb-4">
    <%= link_to "← 一覧に戻る", admin_gyms_path, class: "text-blue-600 hover:underline text-sm" %>
    <%= link_to "編集", edit_admin_gym_path(@gym), class: "bg-yellow-500 text-white px-4 py-2 rounded hover:bg-yellow-600 text-sm" %>
  </div>

  <div class="bg-white rounded-lg shadow p-6">
    <h1 class="text-2xl font-bold mb-6"><%= @gym.name %></h1>

    <table class="text-sm w-full">
      <tbody>
        <tr class="border-b">
          <td class="py-2 text-gray-500 w-32">区</td>
          <td class="py-2"><%= @gym.ward.presence || "−" %></td>
        </tr>
        <tr class="border-b">
          <td class="py-2 text-gray-500">住所</td>
          <td class="py-2"><%= @gym.address.presence || "−" %></td>
        </tr>
        <tr class="border-b">
          <td class="py-2 text-gray-500">郵便番号</td>
          <td class="py-2"><%= @gym.postal_code.presence || "−" %></td>
        </tr>
        <tr class="border-b">
          <td class="py-2 text-gray-500">最寄り駅</td>
          <td class="py-2"><%= @gym.nearest_station.presence || "−" %></td>
        </tr>
        <tr class="border-b">
          <td class="py-2 text-gray-500">電話番号</td>
          <td class="py-2"><%= @gym.phone.presence || "−" %></td>
        </tr>
        <tr class="border-b">
          <td class="py-2 text-gray-500">公式サイト</td>
          <td class="py-2">
            <% if @gym.website.present? %>
              <%= link_to @gym.website, @gym.website,
                  target: "_blank", rel: "noopener noreferrer",
                  class: "text-blue-600 hover:underline break-all" %>
            <% else %>
              <span class="text-gray-400">未登録</span>
            <% end %>
          </td>
        </tr>
        <tr class="border-b">
          <td class="py-2 text-gray-500">区の予約ポータル</td>
          <td class="py-2">
            <% if @gym.reservation_url.present? %>
              <%= link_to @gym.reservation_url, @gym.reservation_url,
                  target: "_blank", rel: "noopener noreferrer",
                  class: "text-blue-600 hover:underline break-all" %>
            <% else %>
              <span class="text-gray-400">未登録</span>
            <% end %>
          </td>
        </tr>
        <tr>
          <td class="py-2 text-gray-500">備考</td>
          <td class="py-2"><%= @gym.notes.presence || "−" %></td>
        </tr>
      </tbody>
    </table>
  </div>
</div>
